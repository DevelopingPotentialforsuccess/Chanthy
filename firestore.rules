rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: allowed_users
    // Document ID: user email
    // Fields:
    //   - email: string (required)
    //   - name: string (required)
    //   - registeredAt: number (required)
    //   - lastLogin: number (required)
    //   - status: string (required, enum: ['active', 'inactive'])
    //   - accessCodeUsed: string (required)
    //
    // Collection: user_settings
    // Document ID: user email
    // Fields:
    //   - brandSettings: map (optional)
    //
    // Collection: generatedTests
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - timestamp: number (required)
    //   - authorEmail: string (required)
    //   - authorName: string (optional)
    //   - authorCode: string (optional)
    //   - module: string (optional)
    //   - level: string (optional)
    //   - topic: string (optional)
    //   - logicSnapshot: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sekchanthyoptimize@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.email is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.registeredAt is number &&
             data.lastLogin is number &&
             data.status in ['active', 'inactive'] &&
             data.accessCodeUsed is string;
    }

    function isValidTest(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000000 &&
             data.timestamp is number &&
             data.authorEmail is string && data.authorEmail == request.auth.token.email;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /allowed_users/{email} {
      // Users can read their own whitelist status
      allow get: if isEmailOwner(email) || isAdmin();
      
      // Users can register themselves if they have the correct passcode (handled by app logic, but rules must allow)
      // We restrict creation to the owner of the email
      allow create: if isEmailOwner(email) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['email', 'name', 'registeredAt', 'lastLogin', 'status', 'accessCodeUsed']);
      
      // Users can update their own last login
      allow update: if isEmailOwner(email) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['email', 'name', 'registeredAt', 'lastLogin', 'status', 'accessCodeUsed']);
      
      // Admins can do anything
      allow read, write: if isAdmin();
    }

    match /user_settings/{email} {
      allow read, write: if isEmailOwner(email) || isAdmin();
    }

    match /generatedTests/{testId} {
      // Users can only see their own tests
      allow list: if isAuthenticated() && (request.query.limit <= 30 && request.query.filters.authorEmail == request.auth.token.email) || isAdmin();
      allow get: if isAuthenticated() && (resource.data.authorEmail == request.auth.token.email) || isAdmin();
      
      // Users can create their own tests
      allow create: if isAuthenticated() && isValidTest(request.resource.data) || isAdmin();
      
      // Users can update/delete their own tests
      allow update, delete: if isAuthenticated() && (resource.data.authorEmail == request.auth.token.email) || isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
